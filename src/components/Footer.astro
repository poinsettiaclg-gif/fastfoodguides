---
const year = new Date().getFullYear();
---

<footer>
	<div class="footer-inner">
		<div class="footer-main">
			<p class="copyright">
				&copy; {year} Fast Food Guides. All rights reserved.
			</p>
			<p class="tagline">
				Behind-the-counter guides from real QSR veterans.
			</p>
		</div>

		<nav class="footer-nav" aria-label="Footer navigation">
			<a href="/privacy">Privacy Policy</a>
			<span class="separator" aria-hidden="true">|</span>
			<a href="/terms">Terms of Service</a>
			<span class="separator" aria-hidden="true">|</span>
			<a href="/disclaimer">Disclaimer</a>
			<span class="separator" aria-hidden="true">|</span>
			<a href="/contact">Contact</a>
		</nav>
	</div>
</footer>

<!-- Cookie Consent Banner -->
<div id="cookie-consent-banner" style="display: none; position: fixed; bottom: 0; left: 0; right: 0; z-index: 9999; background: rgba(10, 15, 28, 0.92); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border-top: 1px solid rgba(16, 185, 129, 0.2); padding: 1.25rem 2rem; box-shadow: 0 -4px 30px rgba(0, 0, 0, 0.4);">
	<div style="max-width: 1100px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; flex-wrap: wrap;">
		<p style="color: #94A3B8; font-size: 0.9rem; margin: 0; line-height: 1.5; flex: 1; min-width: 280px;">
			This site uses cookies to improve your experience and display relevant ads.
			By continuing to browse, you agree to our use of cookies.
			<a href="/privacy" style="color: #10B981; text-decoration: underline; text-underline-offset: 2px; margin-left: 0.25rem;">Learn More</a>
		</p>
		<button id="cookie-accept-btn" style="background: linear-gradient(135deg, #10B981, #06D6A0); color: #0a0f1c; border: none; padding: 0.6rem 1.75rem; border-radius: 0.5rem; font-weight: 600; font-size: 0.9rem; cursor: pointer; white-space: nowrap; transition: transform 0.2s ease, box-shadow 0.2s ease; box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);">Accept</button>
	</div>
</div>
<script is:inline>
	(function() {
		if (!localStorage.getItem('cookie-consent')) {
			document.getElementById('cookie-consent-banner').style.display = 'block';
		}
		document.getElementById('cookie-accept-btn').addEventListener('click', function() {
			localStorage.setItem('cookie-consent', 'accepted');
			var banner = document.getElementById('cookie-consent-banner');
			banner.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
			banner.style.opacity = '0';
			banner.style.transform = 'translateY(100%)';
			setTimeout(function() { banner.style.display = 'none'; }, 300);
		});
	})();
</script>

<style>
	footer {
		background-color: #0a0f1c;
		border-top: 1px solid rgba(16, 185, 129, 0.15);
		padding: 3em 1.5em 2.5em;
		margin-top: auto;
	}

	.footer-inner {
		max-width: 1100px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.25em;
		text-align: center;
	}

	.footer-main {
		display: flex;
		flex-direction: column;
		gap: 0.25em;
	}

	.copyright {
		margin: 0;
		color: #94A3B8;
		font-size: 0.9rem;
		font-weight: 500;
	}

	.tagline {
		margin: 0;
		color: #64748B;
		font-size: 0.825rem;
		font-style: italic;
	}

	.footer-nav {
		display: flex;
		align-items: center;
		gap: 0.75em;
		flex-wrap: wrap;
		justify-content: center;
	}

	.footer-nav a {
		color: #64748B;
		text-decoration: none;
		font-size: 0.85rem;
		transition: color 0.2s ease;
	}
	.footer-nav a:hover {
		color: #10B981;
	}

	.separator {
		color: rgba(255, 255, 255, 0.12);
		font-size: 0.8rem;
		user-select: none;
	}

	@media (max-width: 480px) {
		footer {
			padding: 2em 1em 2em;
		}

		.footer-nav {
			flex-direction: column;
			gap: 0.5em;
		}

		.separator {
			display: none;
		}
	}
</style>
