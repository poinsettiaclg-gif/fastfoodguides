---
const year = new Date().getFullYear();
---

<footer>
	<div class="footer-inner">
		<div class="footer-main">
			<p class="copyright">
				&copy; {year} Fast Food Guides. All rights reserved.
			</p>
			<p class="tagline">
				Behind-the-counter guides from real QSR veterans.
			</p>
		</div>

		<nav class="footer-nav" aria-label="Footer navigation">
			<a href="/privacy">Privacy Policy</a>
			<span class="separator" aria-hidden="true">|</span>
			<a href="/terms">Terms of Service</a>
			<span class="separator" aria-hidden="true">|</span>
			<a href="/disclaimer">Disclaimer</a>
			<span class="separator" aria-hidden="true">|</span>
			<a href="/contact">Contact</a>
			<span class="separator" aria-hidden="true">|</span>
			<a href="#" id="do-not-sell-link">Do Not Sell My Info</a>
		</nav>
	</div>
</footer>

<!-- Cookie Consent Banner (GDPR + CCPA Compliant) -->
<div id="cookie-consent-banner" class="consent-banner" role="dialog" aria-label="Cookie consent" aria-describedby="consent-message">
	<div class="consent-inner">
		<p id="consent-message" class="consent-text">
			We use cookies for analytics and advertising. You can choose to accept or reject non-essential cookies.
			<a href="/privacy" class="consent-link">Privacy Policy</a>
		</p>
		<div class="consent-buttons">
			<button id="cookie-reject-btn" class="consent-btn consent-btn-reject">Reject</button>
			<button id="cookie-accept-btn" class="consent-btn consent-btn-accept">Accept All</button>
		</div>
	</div>
</div>

<!-- Do Not Sell Modal (CCPA) -->
<div id="dns-modal" class="dns-modal" role="dialog" aria-label="Do Not Sell My Personal Information" style="display: none;">
	<div class="dns-modal-inner">
		<h3>Do Not Sell My Personal Information</h3>
		<p>Under the California Consumer Privacy Act (CCPA), you have the right to opt out of the sale of your personal information. We use advertising cookies that may constitute a "sale" under CCPA.</p>
		<p>Current status: <strong id="dns-status">Opted In</strong></p>
		<div class="consent-buttons">
			<button id="dns-optout-btn" class="consent-btn consent-btn-reject">Opt Out of Sale</button>
			<button id="dns-close-btn" class="consent-btn consent-btn-accept">Close</button>
		</div>
	</div>
</div>

<script is:inline>
	(function() {
		var banner = document.getElementById('cookie-consent-banner');
		var consent = localStorage.getItem('cookie-consent');

		// Show banner if no consent decision made yet
		if (!consent) {
			banner.style.display = 'flex';
		}

		function updateConsent(granted) {
			if (typeof gtag === 'function') {
				if (granted) {
					gtag('consent', 'update', {
						'ad_storage': 'granted',
						'ad_user_data': 'granted',
						'ad_personalization': 'granted',
						'analytics_storage': 'granted'
					});
				} else {
					gtag('consent', 'update', {
						'ad_storage': 'denied',
						'ad_user_data': 'denied',
						'ad_personalization': 'denied',
						'analytics_storage': 'denied'
					});
				}
			}
		}

		function hideBanner() {
			banner.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
			banner.style.opacity = '0';
			banner.style.transform = 'translateY(100%)';
			setTimeout(function() { banner.style.display = 'none'; }, 300);
		}

		// Accept All
		document.getElementById('cookie-accept-btn').addEventListener('click', function() {
			localStorage.setItem('cookie-consent', 'accepted');
			updateConsent(true);
			hideBanner();
		});

		// Reject
		document.getElementById('cookie-reject-btn').addEventListener('click', function() {
			localStorage.setItem('cookie-consent', 'rejected');
			updateConsent(false);
			hideBanner();
		});

		// Do Not Sell link (CCPA)
		var dnsLink = document.getElementById('do-not-sell-link');
		var dnsModal = document.getElementById('dns-modal');
		var dnsStatus = document.getElementById('dns-status');

		if (dnsLink) {
			dnsLink.addEventListener('click', function(e) {
				e.preventDefault();
				var current = localStorage.getItem('cookie-consent');
				dnsStatus.textContent = (current === 'rejected') ? 'Opted Out' : 'Opted In';
				dnsModal.style.display = 'flex';
			});
		}

		document.getElementById('dns-optout-btn').addEventListener('click', function() {
			localStorage.setItem('cookie-consent', 'rejected');
			updateConsent(false);
			dnsStatus.textContent = 'Opted Out';
			dnsModal.style.display = 'none';
		});

		document.getElementById('dns-close-btn').addEventListener('click', function() {
			dnsModal.style.display = 'none';
		});
	})();
</script>

<style>
	footer {
		background-color: #0a0f1c;
		border-top: 1px solid rgba(16, 185, 129, 0.15);
		padding: 3em 1.5em 2.5em;
		margin-top: auto;
	}

	.footer-inner {
		max-width: 1100px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.25em;
		text-align: center;
	}

	.footer-main {
		display: flex;
		flex-direction: column;
		gap: 0.25em;
	}

	.copyright {
		margin: 0;
		color: #94A3B8;
		font-size: 0.9rem;
		font-weight: 500;
	}

	.tagline {
		margin: 0;
		color: #64748B;
		font-size: 0.825rem;
		font-style: italic;
	}

	.footer-nav {
		display: flex;
		align-items: center;
		gap: 0.75em;
		flex-wrap: wrap;
		justify-content: center;
	}

	.footer-nav a {
		color: #64748B;
		text-decoration: none;
		font-size: 0.85rem;
		transition: color 0.2s ease;
	}
	.footer-nav a:hover {
		color: #10B981;
	}

	.separator {
		color: rgba(255, 255, 255, 0.12);
		font-size: 0.8rem;
		user-select: none;
	}

	/* Cookie Consent Banner */
	.consent-banner {
		display: none;
		position: fixed;
		bottom: 0;
		left: 0;
		right: 0;
		z-index: 9999;
		background: rgba(10, 15, 28, 0.95);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		border-top: 1px solid rgba(16, 185, 129, 0.2);
		padding: 1.25rem 2rem;
		box-shadow: 0 -4px 30px rgba(0, 0, 0, 0.4);
		align-items: center;
		justify-content: center;
	}

	.consent-inner {
		max-width: 1100px;
		width: 100%;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		flex-wrap: wrap;
	}

	.consent-text {
		color: #94A3B8;
		font-size: 0.9rem;
		margin: 0;
		line-height: 1.5;
		flex: 1;
		min-width: 280px;
	}

	.consent-link {
		color: #10B981;
		text-decoration: underline;
		text-underline-offset: 2px;
		margin-left: 0.25rem;
	}

	.consent-buttons {
		display: flex;
		gap: 0.75rem;
		flex-shrink: 0;
	}

	.consent-btn {
		border: none;
		padding: 0.6rem 1.5rem;
		border-radius: 0.5rem;
		font-weight: 600;
		font-size: 0.9rem;
		cursor: pointer;
		white-space: nowrap;
		transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
	}

	.consent-btn:hover {
		transform: translateY(-1px);
	}

	.consent-btn-accept {
		background: linear-gradient(135deg, #10B981, #06D6A0);
		color: #0a0f1c;
		box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
	}

	.consent-btn-reject {
		background: rgba(255, 255, 255, 0.1);
		color: #94A3B8;
		border: 1px solid rgba(255, 255, 255, 0.15);
	}

	.consent-btn-reject:hover {
		background: rgba(255, 255, 255, 0.15);
		color: #F1F5F9;
	}

	/* Do Not Sell Modal */
	.dns-modal {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		z-index: 10000;
		background: rgba(0, 0, 0, 0.7);
		align-items: center;
		justify-content: center;
	}

	.dns-modal-inner {
		background: #111827;
		border: 1px solid rgba(16, 185, 129, 0.2);
		border-radius: 1rem;
		padding: 2rem;
		max-width: 500px;
		width: 90%;
		color: #CBD5E1;
	}

	.dns-modal-inner h3 {
		color: #F1F5F9;
		margin: 0 0 1rem 0;
		font-size: 1.25rem;
	}

	.dns-modal-inner p {
		margin: 0 0 1rem 0;
		font-size: 0.95rem;
		line-height: 1.6;
	}

	@media (max-width: 480px) {
		footer {
			padding: 2em 1em 2em;
		}

		.footer-nav {
			flex-direction: column;
			gap: 0.5em;
		}

		.separator {
			display: none;
		}

		.consent-inner {
			flex-direction: column;
			text-align: center;
		}

		.consent-buttons {
			width: 100%;
			justify-content: center;
		}
	}
</style>
