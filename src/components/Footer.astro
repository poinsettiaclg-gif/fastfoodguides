---
import CookieBanner from './CookieBanner.astro';
const year = new Date().getFullYear();
---

<CookieBanner />

<footer>
	<div class="footer-inner">
		<div class="footer-main">
			<p class="copyright">
				&copy; {year} Fast Food Guides. All rights reserved.
			</p>
			<p class="tagline">
				Behind-the-counter guides from real QSR veterans.
			</p>
		</div>

		<nav class="footer-nav" aria-label="Footer navigation">
			<a href="/privacy">Privacy Policy</a>
			<span class="separator" aria-hidden="true">|</span>
			<a href="/terms">Terms of Service</a>
			<span class="separator" aria-hidden="true">|</span>
			<a href="/disclaimer">Disclaimer</a>
			<span class="separator" aria-hidden="true">|</span>
			<a href="/contact">Contact</a>
			<span class="separator" aria-hidden="true">|</span>
			<button id="do-not-sell-link" class="link-button">Do Not Sell My Info</button>
		</nav>
	</div>
</footer>



<!-- Do Not Sell Modal (CCPA) -->
<div id="dns-modal" class="dns-modal" role="dialog" aria-modal="true" aria-labelledby="dns-modal-title" style="display: none;">
	<div class="dns-modal-inner">
		<h3 id="dns-modal-title">Do Not Sell My Personal Information</h3>
		<p>Under the California Consumer Privacy Act (CCPA), you have the right to opt out of the sale of your personal information. We use advertising cookies that may constitute a "sale" under CCPA.</p>
		<p>Current status: <strong id="dns-status">Opted In</strong></p>
		<div class="consent-buttons">
			<button id="dns-optout-btn" class="consent-btn consent-btn-reject">Opt Out of Sale</button>
			<button id="dns-close-btn" class="consent-btn consent-btn-accept">Close</button>
		</div>
	</div>
</div>

<script is:inline>
	(function() {
		var dnsLink = document.getElementById('do-not-sell-link');
		var dnsModal = document.getElementById('dns-modal');
		var dnsStatus = document.getElementById('dns-status');
		
		var consent = localStorage.getItem('cookie-consent');
		if (consent === 'rejected') {
			dnsStatus.textContent = 'Opted Out';
		}

		dnsLink.addEventListener('click', function(e) {
			e.preventDefault();
			dnsModal.style.display = 'flex';
			document.getElementById('dns-close-btn').focus();
		});

		document.getElementById('dns-optout-btn').addEventListener('click', function() {
			localStorage.setItem('cookie-consent', 'rejected');
			dnsStatus.textContent = 'Opted Out';
			dnsModal.style.display = 'none';
			dnsLink.focus();
		});

		document.getElementById('dns-close-btn').addEventListener('click', function() {
			dnsModal.style.display = 'none';
			dnsLink.focus();
		});

		// Focus trap
		const focusableElements = 'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])';
		const focusableContent = dnsModal.querySelectorAll(focusableElements);
		const firstFocusableElement = focusableContent[0];
		const lastFocusableElement = focusableContent[focusableContent.length - 1];

		document.addEventListener('keydown', function(e) {
			if (dnsModal.style.display === 'none') return;
			if (e.key === 'Escape') {
				dnsModal.style.display = 'none';
				dnsLink.focus();
				return;
			}
			let isTabPressed = e.key === 'Tab' || e.keyCode === 9;
			if (!isTabPressed) return;
			if (e.shiftKey) { 
				if (document.activeElement === firstFocusableElement) {
					lastFocusableElement.focus();
					e.preventDefault();
				}
			} else { 
				if (document.activeElement === lastFocusableElement) {
					firstFocusableElement.focus();
					e.preventDefault();
				}
			}
		});
	})();
</script>

<style>
	footer {
		background-color: #0a0f1c;
		border-top: 1px solid rgba(16, 185, 129, 0.15);
		padding: 3em 1.5em 2.5em;
		margin-top: auto;
	}

	.footer-inner {
		max-width: 1100px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.25em;
		text-align: center;
	}

	.footer-main {
		display: flex;
		flex-direction: column;
		gap: 0.25em;
	}

	.copyright {
		margin: 0;
		color: #94A3B8;
		font-size: 0.9rem;
		font-weight: 500;
	}

	.tagline {
		margin: 0;
		color: #94A3B8;
		font-size: 0.825rem;
		font-style: italic;
	}

	.footer-nav {
		display: flex;
		align-items: center;
		gap: 0.75em;
		flex-wrap: wrap;
		justify-content: center;
	}

	.footer-nav a, .link-button {
		color: #94A3B8;
		text-decoration: none;
		font-size: 0.85rem;
		transition: color 0.2s ease;
		background: none;
		border: none;
		padding: 0.5rem;
		font-family: inherit;
		cursor: pointer;
	}
	.footer-nav a:hover, .link-button:hover {
		color: #10B981;
	}

	.separator {
		color: rgba(255, 255, 255, 0.12);
		font-size: 0.8rem;
		user-select: none;
	}

	/* CCPA Modal */
	.dns-modal {
		position: fixed;
		top: 0; left: 0; right: 0; bottom: 0;
		background: rgba(10, 15, 28, 0.85);
		backdrop-filter: blur(8px);
		z-index: 10000;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 1.5rem;
	}
	.dns-modal-inner {
		background: #1a2332;
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 1rem;
		padding: 2rem;
		max-width: 500px;
		width: 100%;
		text-align: center;
		box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
	}
	.dns-modal-inner h3 {
		color: #F1F5F9;
		margin: 0 0 1rem 0;
	}
	.dns-modal-inner p {
		color: #94A3B8;
		font-size: 0.95rem;
		line-height: 1.6;
		margin-bottom: 1.5rem;
	}
	#dns-status {
		color: #10B981;
	}

	.consent-buttons {
		display: flex;
		gap: 1rem;
		justify-content: center;
	}
	.consent-btn {
		padding: 0.75rem 1.5rem;
		border-radius: 0.5rem;
		font-weight: 600;
		font-size: 0.95rem;
		cursor: pointer;
		transition: all 0.2s ease;
		border: none;
	}
	.consent-btn-accept {
		background: linear-gradient(135deg, #10B981 0%, #059669 100%);
		color: #ffffff;
	}
	.consent-btn-accept:hover {
		box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
		transform: translateY(-1px);
	}
	.consent-btn-reject {
		background: rgba(255, 255, 255, 0.05);
		color: #F1F5F9;
		border: 1px solid rgba(255, 255, 255, 0.1);
	}
	.consent-btn-reject:hover {
		background: rgba(255, 255, 255, 0.1);
	}
</style>
