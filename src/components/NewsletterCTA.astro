---

<div class="newsletter-cta">
	<div class="newsletter-icon" aria-hidden="true">
		<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
			<polyline points="22,6 12,13 2,6"></polyline>
		</svg>
	</div>
	<div class="newsletter-content">
		<h3>Get the Fast Food Insider Newsletter</h3>
		<p>Once a week, I break down the operational secrets that the corporate training manuals leave out. No spam, just the gritty reality of the kitchen.</p>
		<form id="newsletter-form" class="newsletter-form">
			<label for="email-address" class="sr-only">Email address</label>
			<input id="email-address" name="email" type="email" autocomplete="email" required placeholder="Enter your email" />
			<button type="submit" id="newsletter-submit">Subscribe</button>
		</form>
		<p id="newsletter-message" class="newsletter-message" style="display: none;"></p>
	</div>
</div>

<script>
	const form = document.getElementById('newsletter-form') as HTMLFormElement;
	const messageEl = document.getElementById('newsletter-message');
	const submitBtn = document.getElementById('newsletter-submit') as HTMLButtonElement;

	if (form && messageEl && submitBtn) {
		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			
			const email = (document.getElementById('email-address') as HTMLInputElement).value;
			
			// Loading state
			submitBtn.disabled = true;
			submitBtn.textContent = 'Subscribing...';
			messageEl.style.display = 'none';
			messageEl.className = 'newsletter-message';

			try {
				const response = await fetch('/api/subscribe', {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json',
					},
					body: JSON.stringify({ email }),
				});

				const data = await response.json();

				if (response.ok) {
					form.style.display = 'none';
					messageEl.textContent = data.message || 'Successfully subscribed!';
					messageEl.classList.add('success');
					messageEl.style.display = 'block';
				} else {
					throw new Error(data.error || 'Something went wrong. Please try again.');
				}
			} catch (error: any) {
				messageEl.textContent = error.message;
				messageEl.classList.add('error');
				messageEl.style.display = 'block';
				submitBtn.disabled = false;
				submitBtn.textContent = 'Subscribe';
			}
		});
	}
</script>

<style>
	.newsletter-cta {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		background-color: #1F2937;
		border: 1px solid rgba(16, 185, 129, 0.2);
		border-radius: 0.75rem;
		padding: 2rem;
		margin: 3rem 0;
	}
	@media (min-width: 640px) {
		.newsletter-cta {
			flex-direction: row;
			align-items: flex-start;
		}
	}
	.newsletter-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 3rem;
		height: 3rem;
		background-color: rgba(16, 185, 129, 0.1);
		color: #10B981;
		border-radius: 0.5rem;
		flex-shrink: 0;
	}
	.newsletter-content h3 {
		color: #F1F5F9;
		margin: 0 0 0.5rem 0;
		font-size: 1.25rem;
	}
	.newsletter-content p {
		color: #94A3B8;
		margin: 0 0 1.5rem 0;
		line-height: 1.5;
	}
	.newsletter-form {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	@media (min-width: 480px) {
		.newsletter-form {
			flex-direction: row;
		}
	}
	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border-width: 0;
	}
	.newsletter-form input {
		flex: 1;
		min-width: 0;
		padding: 0.75rem 1rem;
		border-radius: 0.375rem;
		border: 1px solid #374151;
		background-color: #111827;
		color: #F1F5F9;
		font-size: 1rem;
	}
	.newsletter-form input:focus {
		outline: none;
		border-color: #10B981;
		box-shadow: 0 0 0 1px #10B981;
	}
	.newsletter-form button {
		padding: 0.75rem 1.5rem;
		border-radius: 0.375rem;
		border: none;
		background-color: #10B981;
		color: #022C22;
		font-weight: 600;
		font-size: 1rem;
		cursor: pointer;
		transition: background-color 0.2s ease, opacity 0.2s ease;
		white-space: nowrap;
	}
	.newsletter-form button:hover:not(:disabled) {
		background-color: #059669;
	}
	.newsletter-form button:disabled {
		opacity: 0.7;
		cursor: not-allowed;
	}
	.newsletter-message {
		margin-top: 1rem;
		padding: 0.75rem;
		border-radius: 0.375rem;
		font-size: 0.95rem;
		font-weight: 500;
	}
	.newsletter-message.success {
		background-color: rgba(16, 185, 129, 0.1);
		color: #10B981;
		border: 1px solid rgba(16, 185, 129, 0.2);
	}
	.newsletter-message.error {
		background-color: rgba(239, 68, 68, 0.1);
		color: #EF4444;
		border: 1px solid rgba(239, 68, 68, 0.2);
	}
</style>
