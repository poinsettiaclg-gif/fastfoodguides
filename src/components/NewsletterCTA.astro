---
import { Image } from 'astro:assets';
import safeMenuImg from '../assets/images/safe_menu_infographic.png';
---

<div class="newsletter-cta">
	<div class="newsletter-image-container">
		<Image src={safeMenuImg} alt="The Fast Food Safe Menu Cheat Sheet" width={140} height={180} class="newsletter-preview-img" />
	</div>
	<div class="newsletter-content">
		<h3>Download The Fast Food Safe Menu Cheat Sheet</h3>
		<p>Get instant access to our exclusive, high-res PDF guide detailing exactly what to order (and what to avoid) to keep your meals safe, cheap, and fresh. No fluff, just the gritty reality of the kitchen. Enter your email below to download.</p>
		<form id="newsletter-form" action="https://project-planner-seo-hq.poinsettia-clg.workers.dev/api/subscribe" method="POST" class="newsletter-form">
			<label for="email-address" class="sr-only">Email address</label>
			<input id="email-address" name="email" type="email" autocomplete="email" required placeholder="Enter your email" />
			<button type="submit" id="newsletter-submit">Get the PDF</button>
		</form>
		<p id="newsletter-message" class="newsletter-message" style="display: none;"></p>
	</div>
</div>

<script>
	const form = document.getElementById('newsletter-form') as HTMLFormElement;
	const messageEl = document.getElementById('newsletter-message');
	const submitBtn = document.getElementById('newsletter-submit') as HTMLButtonElement;

	if (form && messageEl && submitBtn) {
		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			
			const email = (document.getElementById('email-address') as HTMLInputElement).value;
			
			// Loading state
			submitBtn.disabled = true;
			submitBtn.textContent = 'Sending...';
			messageEl.style.display = 'none';
			messageEl.className = 'newsletter-message';

			try {
				const response = await fetch('/api/subscribe', {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json',
					},
					body: JSON.stringify({ email }),
				});

				let data;
				try {
					data = await response.json();
				} catch (e) {
					throw new Error('The server is currently unavailable. Please try again later.');
				}

				if (response.ok) {
					form.style.display = 'none';
					messageEl.innerHTML = '<strong>Success!</strong> The download link has been sent to your email.';
					messageEl.classList.add('success');
					messageEl.style.display = 'block';
				} else {
					throw new Error(data?.error || 'Something went wrong. Please try again.');
				}
			} catch (error: any) {
				messageEl.textContent = error.message;
				messageEl.classList.add('error');
				messageEl.style.display = 'block';
				submitBtn.disabled = false;
				submitBtn.textContent = 'Get the PDF';
			}
		});
	}
</script>

<style>
	.newsletter-cta {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		background: linear-gradient(145deg, #1F2937 0%, #111827 100%);
		border: 1px solid rgba(16, 185, 129, 0.3);
		border-radius: 0.75rem;
		padding: 2rem;
		margin: 3rem 0;
		box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.3);
	}
	@media (min-width: 640px) {
		.newsletter-cta {
			flex-direction: row;
			align-items: center;
		}
	}
	.newsletter-image-container {
		display: flex;
		justify-content: center;
		flex-shrink: 0;
	}
	.newsletter-preview-img {
		border-radius: 0.5rem;
		box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.5);
		border: 1px solid rgba(255, 255, 255, 0.1);
		transform: rotate(-2deg);
		transition: transform 0.3s ease;
	}
	.newsletter-preview-img:hover {
		transform: rotate(0deg) scale(1.05);
	}
	.newsletter-content h3 {
		color: #10B981;
		margin: 0 0 0.5rem 0;
		font-size: 1.35rem;
		font-weight: 800;
	}
	.newsletter-content p {
		color: #CBD5E1;
		margin: 0 0 1.5rem 0;
		line-height: 1.6;
	}
	.newsletter-form {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	@media (min-width: 480px) {
		.newsletter-form {
			flex-direction: row;
		}
	}
	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border-width: 0;
	}
	.newsletter-form input {
		flex: 1;
		min-width: 0;
		padding: 0.75rem 1rem;
		border-radius: 0.375rem;
		border: 1px solid #374151;
		background-color: #0B0F19;
		color: #F1F5F9;
		font-size: 1rem;
	}
	.newsletter-form input:focus {
		outline: none;
		border-color: #10B981;
		box-shadow: 0 0 0 1px #10B981;
	}
	.newsletter-form button {
		padding: 0.75rem 1.5rem;
		border-radius: 0.375rem;
		border: none;
		background-color: #10B981;
		color: #022C22;
		font-weight: 700;
		font-size: 1rem;
		cursor: pointer;
		transition: background-color 0.2s ease, opacity 0.2s ease;
		white-space: nowrap;
	}
	.newsletter-form button:hover:not(:disabled) {
		background-color: #059669;
	}
	.newsletter-form button:disabled {
		opacity: 0.7;
		cursor: not-allowed;
	}
	.newsletter-message {
		margin-top: 1rem;
		padding: 0.75rem;
		border-radius: 0.375rem;
		font-size: 0.95rem;
		font-weight: 500;
	}
	.newsletter-message.success {
		background-color: rgba(16, 185, 129, 0.1);
		color: #10B981;
		border: 1px solid rgba(16, 185, 129, 0.2);
	}
	.newsletter-message.error {
		background-color: rgba(239, 68, 68, 0.1);
		color: #EF4444;
		border: 1px solid rgba(239, 68, 68, 0.2);
	}
</style>
