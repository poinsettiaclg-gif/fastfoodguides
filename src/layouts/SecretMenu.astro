---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import NewsletterCTA from '../components/NewsletterCTA.astro';

type Props = CollectionEntry<'secretMenus'>['data'];

const { title, description, pubDate, heroImage, chain, operationalAnnoyanceScore, isVerified, ingredients, howToOrder, priceEstimate } = Astro.props;

// Build breadcrumb path
function slugifyChain(c: string): string {
	return c.toLowerCase().replace(/['']/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
}

// Generate Annoyance Color
let annoyanceColor = '#10B981'; // Green
if (operationalAnnoyanceScore >= 4) annoyanceColor = '#F59E0B'; // Yellow
if (operationalAnnoyanceScore >= 8) annoyanceColor = '#EF4444'; // Red

const schemas = [
	{
		"@context": "https://schema.org",
		"@type": "Recipe",
		"name": title,
		"description": description,
		"image": heroImage ? new URL(heroImage.src, Astro.site) : undefined,
		"recipeIngredient": ingredients,
		"recipeInstructions": [{ "@type": "HowToStep", "text": howToOrder }],
		"author": {
			"@type": "Person",
			"name": "Russell Roseberry"
		}
	}
];
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage?.src} ogType="article" />
		<script type="application/ld+json" set:html={JSON.stringify(schemas)} />
		<style>
			.secret-menu-container {
				max-width: 800px;
				margin: 0 auto;
				padding: 2rem 1rem;
			}
			.chain-badge {
				display: inline-block;
				background-color: #374151;
				color: #F1F5F9;
				padding: 0.25rem 0.75rem;
				border-radius: 9999px;
				font-size: 0.875rem;
				font-weight: 600;
				margin-bottom: 1rem;
				text-decoration: none;
			}
			.sm-header {
				margin-bottom: 2rem;
				text-align: center;
			}
			.sm-header h1 {
				margin: 0 0 1rem 0;
				font-size: 2.5rem;
				color: #F8FAFC;
			}
			.verified-badge {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				background-color: rgba(16, 185, 129, 0.1);
				color: #10B981;
				padding: 0.5rem 1rem;
				border-radius: 0.375rem;
				border: 1px solid rgba(16, 185, 129, 0.2);
				font-weight: 600;
				margin-bottom: 1.5rem;
			}
			.sm-hero {
				width: 100%;
				border-radius: 0.75rem;
				box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.3);
				margin-bottom: 2rem;
			}
			.sm-dashboard {
				display: grid;
				grid-template-columns: 1fr;
				gap: 1.5rem;
				margin-bottom: 2rem;
			}
			@media(min-width: 640px) {
				.sm-dashboard {
					grid-template-columns: 1fr 1fr;
				}
			}
			.sm-card {
				background-color: #1E293B;
				border: 1px solid #334155;
				border-radius: 0.75rem;
				padding: 1.5rem;
			}
			.sm-card h3 {
				margin: 0 0 1rem 0;
				color: #94A3B8;
				font-size: 1rem;
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}
			.annoyance-score {
				font-size: 3rem;
				font-weight: 900;
				line-height: 1;
			}
			.ingredients-list {
				list-style-type: none;
				padding: 0;
				margin: 0;
			}
			.ingredients-list li {
				padding: 0.5rem 0;
				border-bottom: 1px solid #334155;
				color: #E2E8F0;
			}
			.ingredients-list li:last-child {
				border-bottom: none;
			}
			.script-box {
				background-color: #0F172A;
				border-left: 4px solid #3B82F6;
				padding: 1.5rem;
				border-radius: 0.375rem;
				margin-top: 1rem;
				font-family: monospace;
				font-size: 1.125rem;
				color: #60A5FA;
			}
			.prose {
				color: #CBD5E1;
				line-height: 1.7;
				font-size: 1.125rem;
				margin-top: 3rem;
			}
			.prose h2 {
				color: #F8FAFC;
				margin-top: 2rem;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<article class="secret-menu-container">
				<div class="sm-header">
					<a href="/secret-menus/" class="chain-badge">{chain} Secret Menu</a>
					<h1>{title}</h1>
					{isVerified && (
						<div class="verified-badge">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
							Verified by QSR Managers
						</div>
					)}
				</div>

				{heroImage && <img src={heroImage.src} alt={title} class="sm-hero" />}

				<div class="sm-dashboard">
					<div class="sm-card" style={`border-top: 4px solid ${annoyanceColor};`}>
						<h3>Operational Annoyance Score</h3>
						<div class="annoyance-score" style={`color: ${annoyanceColor};`}>{operationalAnnoyanceScore}/10</div>
						<p style="color: #94A3B8; margin-top: 0.5rem;">How much the kitchen will hate you for ordering this.</p>
					</div>

					<div class="sm-card">
						<h3>Ingredients</h3>
						<ul class="ingredients-list">
							{ingredients.map(ing => (
								<li>{ing}</li>
							))}
						</ul>
						{priceEstimate && <p style="margin-top: 1rem; font-weight: 600; color: #E2E8F0;">Est. Price: {priceEstimate}</p>}
					</div>
				</div>

				<div class="sm-card">
					<h3>Exactly What to Say at the Speaker</h3>
					<div class="script-box">
						"{howToOrder}"
					</div>
				</div>

				<div class="prose">
					<slot />
				</div>
				
				<NewsletterCTA />
			</article>
		</main>
		<Footer />
	</body>
</html>
