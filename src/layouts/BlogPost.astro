---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import AuthorBylineTop from '../components/AuthorBylineTop.astro';
import AuthorBylineBottom from '../components/AuthorBylineBottom.astro';

type Props = CollectionEntry<'articles'>['data'];

const { title, description, pubDate, updatedDate, heroImage, author, authorTitle, chain } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			body {
				background: #0a0f1c;
				color: #F1F5F9;
			}

			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding: 0;
			}

			article {
				padding: 2rem 1rem 4rem;
			}

			.prose {
				width: 720px;
				max-width: calc(100% - 2rem);
				margin: 0 auto;
				color: #CBD5E1;
				font-size: 1.05rem;
				line-height: 1.8;
			}

			/* — Title block — */
			.article-header {
				margin-bottom: 2rem;
				padding-bottom: 1.5rem;
				border-bottom: 1px solid rgba(255, 255, 255, 0.08);
			}

			.chain-badge {
				display: inline-block;
				margin-bottom: 0.75rem;
				padding: 0.2em 0.65em;
				font-size: 0.75rem;
				font-weight: 600;
				letter-spacing: 0.04em;
				text-transform: uppercase;
				color: #10B981;
				background: rgba(16, 185, 129, 0.12);
				border: 1px solid rgba(16, 185, 129, 0.3);
				border-radius: 0.375rem;
				line-height: 1.5;
			}

			.article-header h1 {
				margin: 0 0 1rem 0;
				font-size: 2.25rem;
				font-weight: 800;
				color: #F1F5F9;
				line-height: 1.2;
				letter-spacing: -0.02em;
			}

			.updated-note {
				margin-top: 0.5rem;
				font-size: 0.8rem;
				font-style: italic;
				color: #64748B;
			}

			/* — Prose typography — */
			.prose :global(h2) {
				margin: 2.5rem 0 1rem 0;
				font-size: 1.6rem;
				font-weight: 700;
				color: #F1F5F9;
				line-height: 1.3;
			}

			.prose :global(h3) {
				margin: 2rem 0 0.75rem 0;
				font-size: 1.3rem;
				font-weight: 600;
				color: #E2E8F0;
				line-height: 1.35;
			}

			.prose :global(h4) {
				margin: 1.5rem 0 0.5rem 0;
				font-size: 1.1rem;
				font-weight: 600;
				color: #CBD5E1;
				line-height: 1.4;
			}

			.prose :global(p) {
				margin-bottom: 1.5em;
				color: #CBD5E1;
			}

			.prose :global(a) {
				color: #34D399;
				text-decoration: underline;
				text-decoration-color: rgba(52, 211, 153, 0.3);
				text-underline-offset: 0.15em;
				transition: color 0.2s ease, text-decoration-color 0.2s ease;
			}

			.prose :global(a:hover) {
				color: #10B981;
				text-decoration-color: #10B981;
			}

			.prose :global(strong) {
				color: #F1F5F9;
				font-weight: 700;
			}

			.prose :global(ul),
			.prose :global(ol) {
				margin-bottom: 1.5em;
				padding-left: 1.5em;
				color: #CBD5E1;
			}

			.prose :global(li) {
				margin-bottom: 0.5em;
			}

			.prose :global(li::marker) {
				color: #10B981;
			}

			.prose :global(blockquote) {
				margin: 1.5em 0;
				padding: 1em 1.25em;
				border-left: 3px solid #10B981;
				background: rgba(16, 185, 129, 0.06);
				border-radius: 0 0.5rem 0.5rem 0;
				color: #94A3B8;
				font-style: italic;
				font-size: 1em;
			}

			.prose :global(blockquote p) {
				margin-bottom: 0;
			}

			.prose :global(code) {
				padding: 0.15em 0.4em;
				font-size: 0.875em;
				background: rgba(255, 255, 255, 0.08);
				border-radius: 0.25rem;
				color: #34D399;
			}

			.prose :global(pre) {
				margin: 1.5em 0;
				padding: 1.25em;
				background: #111827;
				border: 1px solid rgba(255, 255, 255, 0.08);
				border-radius: 0.5rem;
				overflow-x: auto;
			}

			.prose :global(pre > code) {
				all: unset;
				color: #CBD5E1;
			}

			.prose :global(hr) {
				margin: 2.5rem 0;
				border: none;
				border-top: 1px solid rgba(255, 255, 255, 0.08);
			}

			.prose :global(table) {
				width: 100%;
				margin: 1.5em 0;
				border-collapse: collapse;
			}

			.prose :global(th) {
				padding: 0.75em 1em;
				text-align: left;
				font-weight: 600;
				color: #F1F5F9;
				background: #111827;
				border-bottom: 2px solid rgba(16, 185, 129, 0.3);
				font-size: 0.9rem;
			}

			.prose :global(td) {
				padding: 0.65em 1em;
				border-bottom: 1px solid rgba(255, 255, 255, 0.06);
				font-size: 0.95rem;
			}

			.prose :global(tr:hover td) {
				background: rgba(255, 255, 255, 0.02);
			}

			.prose :global(img) {
				max-width: 100%;
				height: auto;
				border-radius: 0.5rem;
				margin: 1.5em 0;
			}

			/* — Responsive — */
			@media (max-width: 720px) {
				.article-header h1 {
					font-size: 1.75rem;
				}

				article {
					padding: 1.5rem 0.75rem 3rem;
				}

				.prose {
					font-size: 1rem;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="prose">
					<header class="article-header">
						{chain && <span class="chain-badge">{chain}</span>}
						<h1>{title}</h1>
						<AuthorBylineTop author={author} authorTitle={authorTitle} pubDate={pubDate} />
						{
							updatedDate && (
								<p class="updated-note">
									Updated <time datetime={updatedDate.toISOString()}>
										{updatedDate.toLocaleDateString('en-us', {
											year: 'numeric',
											month: 'short',
											day: 'numeric',
										})}
									</time>
								</p>
							)
						}
					</header>

					<slot />

					<AuthorBylineBottom author={author} authorTitle={authorTitle} />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
