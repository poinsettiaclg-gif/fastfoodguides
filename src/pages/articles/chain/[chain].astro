---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import FormattedDate from '../../../components/FormattedDate.astro';

// Chain slug to display name mapping
const chainMap: Record<string, string> = {
  'arbys': "Arby's",
  'burger-king': 'Burger King',
  'chick-fil-a': 'Chick-fil-A',
  'chipotle': 'Chipotle',
  'culvers': "Culver's",
  'dairy-queen': 'Dairy Queen',
  'dennys': "Denny's",
  'dominos': "Domino's",
  'dunkin': "Dunkin'",
  'firehouse-subs': 'Firehouse Subs',
  'five-guys': 'Five Guys',
  'hardees-carls-jr': "Hardee's / Carl's Jr.",
  'ihop': 'IHOP',
  'in-n-out-burger': 'In-N-Out Burger',
  'jack-in-the-box': 'Jack in the Box',
  'jersey-mikes': "Jersey Mike's",
  'jimmy-johns': "Jimmy John's",
  'kfc': 'KFC',
  'krispy-kreme': 'Krispy Kreme',
  'little-caesars': 'Little Caesars',
  'mcdonalds': "McDonald's",
  'multi-chain': 'Multi-Chain',
  'panda-express': 'Panda Express',
  'panera-bread': 'Panera Bread',
  'papa-johns': "Papa John's",
  'pizza-hut': 'Pizza Hut',
  'popeyes': 'Popeyes',
  'raising-canes': "Raising Cane's",
  'shake-shack': 'Shake Shack',
  'sonic-drive-in': 'Sonic Drive-In',
  'starbucks': 'Starbucks',
  'subway': 'Subway',
  'taco-bell': 'Taco Bell',
  'waffle-house': 'Waffle House',
  'wawa': 'Wawa',
  'wendys': "Wendy's",
  'whataburger': 'Whataburger',
  'white-castle': 'White Castle',
  'wingstop': 'Wingstop',
  'zaxbys': "Zaxby's",
};

function slugifyChain(chain: string): string {
  return chain
    .toLowerCase()
    .replace(/[']/g, '')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '');
}

export async function getStaticPaths() {
  function slugifyChain(chain: string): string {
    return chain
      .toLowerCase()
      .replace(/[']/g, '')
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-|-$/g, '');
  }

  const allPosts = await getCollection('articles');
  const chains = [...new Set(allPosts.map(p => p.data.chain).filter(Boolean))] as string[];

  return chains.map(chain => {
    const slug = slugifyChain(chain);
    const posts = allPosts
      .filter(p => p.data.chain === chain)
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

    return {
      params: { chain: slug },
      props: { chainName: chain, posts },
    };
  });
}

const { chainName, posts } = Astro.props;
const chainSlug = slugifyChain(chainName);
const displayName = chainMap[chainSlug] || chainName;
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead
    title={`${displayName} Guides | Fast Food Guides`}
    description={`Browse all insider guides for ${displayName}. Real tips from real workers.`}
  />
</head>
<body>
  <Header />
  <main>
    <div class="chain-header">
      <a href="/articles/" class="back-link">← All Guides</a>
      <h1>{displayName} Guides</h1>
      <p class="subtitle">{posts.length} insider guide{posts.length !== 1 ? 's' : ''} from real {displayName} workers.</p>
    </div>

    <div class="articles-grid">
      {posts.map((post) => (
        <a href={`/articles/${post.id}/`} class="article-card">
          <h3>{post.data.title}</h3>
          <p class="date"><FormattedDate date={post.data.pubDate} /></p>
          <p class="desc">{post.data.description}</p>
        </a>
      ))}
    </div>
  </main>
  <Footer />
</body>
</html>

<style>
  body {
    background-color: #0a0f1c;
    color: #F1F5F9;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main {
    flex: 1;
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
    width: 100%;
  }

  .chain-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .back-link {
    color: #10B981;
    text-decoration: none;
    font-size: 0.95rem;
    display: inline-block;
    margin-bottom: 1rem;
    transition: opacity 0.2s ease;
  }
  .back-link:hover {
    opacity: 0.8;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    background: linear-gradient(135deg, #F1F5F9, #94A3B8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: #94A3B8;
    font-size: 1.15rem;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .article-card {
    display: block;
    background: #1a2332;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 0.75rem;
    padding: 1.75rem;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .article-card:hover {
    transform: translateY(-4px);
    border-color: rgba(16, 185, 129, 0.3);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
  }

  .article-card h3 {
    color: #10B981;
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  .date {
    font-size: 0.875rem;
    color: #64748B;
    margin-bottom: 0.75rem;
  }

  .desc {
    color: #94A3B8;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  @media (max-width: 640px) {
    .articles-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
