---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import SecretMenu from '../../layouts/SecretMenu.astro';

export async function getStaticPaths() {
	const items = await getCollection('secretMenus');
	return items.map((item) => ({
		params: { slug: item.id },
		props: item,
	}));
}
type Props = CollectionEntry<'secretMenus'>;

const item = Astro.props;
const { Content } = await render(item);
---

<SecretMenu {...item.data}>
	<Content />
</SecretMenu>
